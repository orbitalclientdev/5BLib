--[[
    Clean UI Library for Roblox
    A modern, minimal UI library with smooth animations
    Usage: local Library = loadstring(source)()
]]

local TweenService = game:GetService("TweenService")
local UserInputService = game:GetService("UserInputService")
local RunService = game:GetService("RunService")
local Players = game:GetService("Players")
local Player = Players.LocalPlayer

-- ── Theme ──────────────────────────────────────────────
local Theme = {
    Background      = Color3.fromRGB(18, 18, 22),
    Surface         = Color3.fromRGB(25, 25, 32),
    SurfaceLight    = Color3.fromRGB(32, 32, 42),
    Border          = Color3.fromRGB(45, 45, 58),
    Accent          = Color3.fromRGB(88, 101, 242),
    AccentHover     = Color3.fromRGB(105, 117, 255),
    Text            = Color3.fromRGB(230, 230, 240),
    TextDim         = Color3.fromRGB(140, 140, 165),
    Success         = Color3.fromRGB(67, 181, 129),
    Warning         = Color3.fromRGB(250, 166, 26),
    Error           = Color3.fromRGB(237, 66, 69),
    Font            = Enum.Font.GothamSemibold,
    FontLight       = Enum.Font.Gotham,
    CornerRadius    = UDim.new(0, 8),
    CornerRadiusSm  = UDim.new(0, 6),
    AnimSpeed       = 0.25,
}

-- ── Utility ────────────────────────────────────────────
local function tween(obj, props, duration, style, dir)
    local info = TweenInfo.new(duration or Theme.AnimSpeed, style or Enum.EasingStyle.Quint, dir or Enum.EasingDirection.Out)
    local t = TweenService:Create(obj, info, props)
    t:Play()
    return t
end

local function create(class, props, children)
    local inst = Instance.new(class)
    for k, v in pairs(props or {}) do
        inst[k] = v
    end
    for _, child in ipairs(children or {}) do
        child.Parent = inst
    end
    return inst
end

local function addCorner(parent, radius)
    return create("UICorner", { CornerRadius = radius or Theme.CornerRadius, Parent = parent })
end

local function addStroke(parent, color, thickness)
    return create("UIStroke", { Color = color or Theme.Border, Thickness = thickness or 1, ApplyStrokeMode = Enum.ApplyStrokeMode.Border, Parent = parent })
end

local function addPadding(parent, t, b, l, r)
    return create("UIPadding", { PaddingTop = t or UDim.new(0,8), PaddingBottom = b or t or UDim.new(0,8), PaddingLeft = l or UDim.new(0,12), PaddingRight = r or l or UDim.new(0,12), Parent = parent })
end

local function addShadow(parent)
    local shadow = create("ImageLabel", {
        Name = "Shadow",
        BackgroundTransparency = 1,
        Image = "rbxassetid://6014261993",
        ImageColor3 = Color3.fromRGB(0,0,0),
        ImageTransparency = 0.5,
        Position = UDim2.new(0, -15, 0, -15),
        Size = UDim2.new(1, 30, 1, 30),
        ScaleType = Enum.ScaleType.Slice,
        SliceCenter = Rect.new(49, 49, 450, 450),
        ZIndex = -1,
        Parent = parent,
    })
    return shadow
end

-- ── Library ────────────────────────────────────────────
local Library = {}
Library.__index = Library

function Library:New(title)
    local lib = setmetatable({}, Library)
    lib.title = title or "Clean UI"
    lib.windows = {}
    lib.toggled = true
    lib.notifications = {}

    -- ScreenGui
    lib.gui = create("ScreenGui", {
        Name = "CleanUI",
        ZIndexBehavior = Enum.ZIndexBehavior.Sibling,
        ResetOnSpawn = false,
    })

    -- Try parenting
    pcall(function()
        lib.gui.Parent = game:GetService("CoreGui")
    end)
    if not lib.gui.Parent then
        lib.gui.Parent = Player:WaitForChild("PlayerGui")
    end

    -- Notification holder
    lib.notifHolder = create("Frame", {
        Name = "Notifications",
        BackgroundTransparency = 1,
        AnchorPoint = Vector2.new(1, 1),
        Position = UDim2.new(1, -20, 1, -20),
        Size = UDim2.new(0, 300, 1, -40),
        Parent = lib.gui,
    })
    create("UIListLayout", {
        SortOrder = Enum.SortOrder.LayoutOrder,
        VerticalAlignment = Enum.VerticalAlignment.Bottom,
        Padding = UDim.new(0, 8),
        Parent = lib.notifHolder,
    })

    -- Toggle keybind (RightControl)
    lib._toggleConn = UserInputService.InputBegan:Connect(function(input, gpe)
        if gpe then return end
        if input.KeyCode == Enum.KeyCode.RightControl then
            lib.toggled = not lib.toggled
            lib.gui.Enabled = lib.toggled
        end
    end)

    return lib
end

-- ── Notification ───────────────────────────────────────
function Library:Notify(cfg)
    cfg = cfg or {}
    local title = cfg.Title or "Notification"
    local message = cfg.Message or ""
    local duration = cfg.Duration or 4
    local ntype = cfg.Type or "Info" -- Info, Success, Warning, Error

    local accentColor = Theme.Accent
    if ntype == "Success" then accentColor = Theme.Success
    elseif ntype == "Warning" then accentColor = Theme.Warning
    elseif ntype == "Error" then accentColor = Theme.Error end

    local card = create("Frame", {
        Name = "Notification",
        BackgroundColor3 = Theme.Surface,
        Size = UDim2.new(1, 0, 0, 0),
        AutomaticSize = Enum.AutomaticSize.Y,
        ClipsDescendants = true,
        Parent = self.notifHolder,
    })
    addCorner(card)
    addStroke(card, accentColor)

    -- Accent bar
    create("Frame", {
        BackgroundColor3 = accentColor,
        Size = UDim2.new(0, 3, 1, 0),
        BorderSizePixel = 0,
        Parent = card,
    })

    local content = create("Frame", {
        BackgroundTransparency = 1,
        Size = UDim2.new(1, 0, 0, 0),
        AutomaticSize = Enum.AutomaticSize.Y,
        Parent = card,
    })
    addPadding(content, UDim.new(0,10), UDim.new(0,10), UDim.new(0,16), UDim.new(0,12))
    create("UIListLayout", { SortOrder = Enum.SortOrder.LayoutOrder, Padding = UDim.new(0,4), Parent = content })

    create("TextLabel", {
        Name = "Title",
        BackgroundTransparency = 1,
        Size = UDim2.new(1, 0, 0, 0),
        AutomaticSize = Enum.AutomaticSize.Y,
        Font = Theme.Font,
        Text = title,
        TextColor3 = Theme.Text,
        TextSize = 14,
        TextXAlignment = Enum.TextXAlignment.Left,
        Parent = content,
    })
    create("TextLabel", {
        Name = "Message",
        BackgroundTransparency = 1,
        Size = UDim2.new(1, 0, 0, 0),
        AutomaticSize = Enum.AutomaticSize.Y,
        Font = Theme.FontLight,
        Text = message,
        TextColor3 = Theme.TextDim,
        TextSize = 13,
        TextWrapped = true,
        TextXAlignment = Enum.TextXAlignment.Left,
        Parent = content,
    })

    -- Animate in
    card.BackgroundTransparency = 1
    tween(card, { BackgroundTransparency = 0 }, 0.3)

    -- Auto dismiss
    task.delay(duration, function()
        tween(card, { BackgroundTransparency = 1 }, 0.3)
        task.wait(0.35)
        card:Destroy()
    end)
end

-- ── Window ─────────────────────────────────────────────
function Library:Window(cfg)
    cfg = cfg or {}
    local win = {}
    win.title = cfg.Title or "Window"
    win.size = cfg.Size or UDim2.new(0, 520, 0, 380)
    win.tabs = {}
    win.activeTab = nil

    -- Main frame
    win.frame = create("Frame", {
        Name = "Window",
        BackgroundColor3 = Theme.Background,
        Position = UDim2.new(0.5, -260, 0.5, -190),
        Size = win.size,
        ClipsDescendants = true,
        Parent = self.gui,
    })
    addCorner(win.frame)
    addStroke(win.frame)
    addShadow(win.frame)

    -- ── Title Bar ──
    win.titleBar = create("Frame", {
        Name = "TitleBar",
        BackgroundColor3 = Theme.Surface,
        Size = UDim2.new(1, 0, 0, 40),
        BorderSizePixel = 0,
        Parent = win.frame,
    })
    addCorner(win.titleBar)

    -- bottom corner mask for title bar
    create("Frame", {
        BackgroundColor3 = Theme.Surface,
        Position = UDim2.new(0, 0, 1, -8),
        Size = UDim2.new(1, 0, 0, 8),
        BorderSizePixel = 0,
        Parent = win.titleBar,
    })

    create("TextLabel", {
        Name = "Title",
        BackgroundTransparency = 1,
        Position = UDim2.new(0, 14, 0, 0),
        Size = UDim2.new(1, -80, 1, 0),
        Font = Theme.Font,
        Text = win.title,
        TextColor3 = Theme.Text,
        TextSize = 15,
        TextXAlignment = Enum.TextXAlignment.Left,
        Parent = win.titleBar,
    })

    -- Close button
    local closeBtn = create("TextButton", {
        Name = "Close",
        BackgroundTransparency = 1,
        Position = UDim2.new(1, -36, 0, 4),
        Size = UDim2.new(0, 32, 0, 32),
        Font = Theme.Font,
        Text = "×",
        TextColor3 = Theme.TextDim,
        TextSize = 22,
        Parent = win.titleBar,
    })
    closeBtn.MouseButton1Click:Connect(function()
        tween(win.frame, { Size = UDim2.new(0, win.size.X.Offset, 0, 0) }, 0.35)
        task.wait(0.4)
        win.frame.Visible = false
    end)
    closeBtn.MouseEnter:Connect(function() tween(closeBtn, { TextColor3 = Theme.Error }, 0.15) end)
    closeBtn.MouseLeave:Connect(function() tween(closeBtn, { TextColor3 = Theme.TextDim }, 0.15) end)

    -- Minimize button
    local minBtn = create("TextButton", {
        Name = "Minimize",
        BackgroundTransparency = 1,
        Position = UDim2.new(1, -64, 0, 4),
        Size = UDim2.new(0, 32, 0, 32),
        Font = Theme.Font,
        Text = "–",
        TextColor3 = Theme.TextDim,
        TextSize = 20,
        Parent = win.titleBar,
    })
    local minimized = false
    minBtn.MouseButton1Click:Connect(function()
        minimized = not minimized
        if minimized then
            tween(win.frame, { Size = UDim2.new(0, win.size.X.Offset, 0, 40) }, 0.3)
        else
            tween(win.frame, { Size = win.size }, 0.3)
        end
    end)
    minBtn.MouseEnter:Connect(function() tween(minBtn, { TextColor3 = Theme.Warning }, 0.15) end)
    minBtn.MouseLeave:Connect(function() tween(minBtn, { TextColor3 = Theme.TextDim }, 0.15) end)

    -- ── Dragging ──
    local dragging, dragStart, startPos
    win.titleBar.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = true
            dragStart = input.Position
            startPos = win.frame.Position
        end
    end)
    win.titleBar.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = false
        end
    end)
    UserInputService.InputChanged:Connect(function(input)
        if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
            local delta = input.Position - dragStart
            win.frame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
        end
    end)

    -- ── Tab sidebar ──
    win.tabList = create("Frame", {
        Name = "TabList",
        BackgroundColor3 = Theme.Surface,
        Position = UDim2.new(0, 0, 0, 40),
        Size = UDim2.new(0, 140, 1, -40),
        BorderSizePixel = 0,
        Parent = win.frame,
    })
    -- Bottom corner rounding mask
    create("UICorner", { CornerRadius = Theme.CornerRadius, Parent = win.tabList })
    create("Frame", { BackgroundColor3 = Theme.Surface, Size = UDim2.new(1,0,0,8), BorderSizePixel = 0, Parent = win.tabList })
    -- Right side cover
    create("Frame", { BackgroundColor3 = Theme.Surface, Position = UDim2.new(1,-8,0,0), Size = UDim2.new(0,8,1,0), BorderSizePixel = 0, Parent = win.tabList })

    win.tabButtonHolder = create("Frame", {
        Name = "TabButtons",
        BackgroundTransparency = 1,
        Position = UDim2.new(0, 0, 0, 8),
        Size = UDim2.new(1, 0, 1, -8),
        Parent = win.tabList,
    })
    addPadding(win.tabButtonHolder, UDim.new(0,4), UDim.new(0,4), UDim.new(0,8), UDim.new(0,8))
    create("UIListLayout", { SortOrder = Enum.SortOrder.LayoutOrder, Padding = UDim.new(0,4), Parent = win.tabButtonHolder })

    -- ── Tab content area ──
    win.tabContent = create("Frame", {
        Name = "TabContent",
        BackgroundTransparency = 1,
        Position = UDim2.new(0, 140, 0, 40),
        Size = UDim2.new(1, -140, 1, -40),
        Parent = win.frame,
    })

    -- Divider line
    create("Frame", {
        BackgroundColor3 = Theme.Border,
        Position = UDim2.new(0, 140, 0, 40),
        Size = UDim2.new(0, 1, 1, -40),
        BorderSizePixel = 0,
        Parent = win.frame,
    })

    -- Open animation
    win.frame.Size = UDim2.new(0, win.size.X.Offset, 0, 0)
    win.frame.BackgroundTransparency = 1
    tween(win.frame, { Size = win.size, BackgroundTransparency = 0 }, 0.4)

    -- ── Tab method ──
    function win:Tab(tabCfg)
        tabCfg = tabCfg or {}
        local tab = {}
        tab.name = tabCfg.Name or "Tab"
        tab.elements = {}

        -- Tab button
        tab.button = create("TextButton", {
            Name = tab.name,
            BackgroundColor3 = Theme.SurfaceLight,
            BackgroundTransparency = 1,
            Size = UDim2.new(1, 0, 0, 32),
            Font = Theme.FontLight,
            Text = tab.name,
            TextColor3 = Theme.TextDim,
            TextSize = 13,
            Parent = win.tabButtonHolder,
        })
        addCorner(tab.button, Theme.CornerRadiusSm)

        -- Tab page (scrolling)
        tab.page = create("ScrollingFrame", {
            Name = tab.name,
            BackgroundTransparency = 1,
            Size = UDim2.new(1, 0, 1, 0),
            CanvasSize = UDim2.new(0, 0, 0, 0),
            AutomaticCanvasSize = Enum.AutomaticSize.Y,
            ScrollBarThickness = 3,
            ScrollBarImageColor3 = Theme.Accent,
            BorderSizePixel = 0,
            Visible = false,
            Parent = win.tabContent,
        })
        addPadding(tab.page, UDim.new(0,10), UDim.new(0,10), UDim.new(0,14), UDim.new(0,14))
        create("UIListLayout", { SortOrder = Enum.SortOrder.LayoutOrder, Padding = UDim.new(0,6), Parent = tab.page })

        -- Switch logic
        local function activate()
            for _, t in ipairs(win.tabs) do
                t.page.Visible = false
                tween(t.button, { BackgroundTransparency = 1, TextColor3 = Theme.TextDim }, 0.2)
            end
            tab.page.Visible = true
            tween(tab.button, { BackgroundTransparency = 0, TextColor3 = Theme.Text }, 0.2)
            win.activeTab = tab
        end
        tab.button.MouseButton1Click:Connect(activate)

        -- First tab auto-activates
        table.insert(win.tabs, tab)
        if #win.tabs == 1 then activate() end

        -- ── Section ──
        function tab:Section(secCfg)
            secCfg = secCfg or {}
            local sec = {}
            sec.name = secCfg.Name or "Section"

            sec.frame = create("Frame", {
                Name = sec.name,
                BackgroundTransparency = 1,
                Size = UDim2.new(1, 0, 0, 0),
                AutomaticSize = Enum.AutomaticSize.Y,
                Parent = tab.page,
            })
            create("UIListLayout", { SortOrder = Enum.SortOrder.LayoutOrder, Padding = UDim.new(0,6), Parent = sec.frame })

            -- Section header
            create("TextLabel", {
                BackgroundTransparency = 1,
                Size = UDim2.new(1, 0, 0, 22),
                Font = Theme.Font,
                Text = sec.name,
                TextColor3 = Theme.TextDim,
                TextSize = 12,
                TextXAlignment = Enum.TextXAlignment.Left,
                Parent = sec.frame,
            })

            -- ── Button ──
            function sec:Button(btnCfg)
                btnCfg = btnCfg or {}
                local btn = create("TextButton", {
                    Name = btnCfg.Name or "Button",
                    BackgroundColor3 = Theme.SurfaceLight,
                    Size = UDim2.new(1, 0, 0, 34),
                    Font = Theme.FontLight,
                    Text = btnCfg.Name or "Button",
                    TextColor3 = Theme.Text,
                    TextSize = 13,
                    Parent = sec.frame,
                })
                addCorner(btn, Theme.CornerRadiusSm)
                addStroke(btn, Theme.Border, 1)

                btn.MouseEnter:Connect(function() tween(btn, { BackgroundColor3 = Theme.Accent }, 0.15) end)
                btn.MouseLeave:Connect(function() tween(btn, { BackgroundColor3 = Theme.SurfaceLight }, 0.15) end)
                btn.MouseButton1Click:Connect(function()
                    if btnCfg.Callback then btnCfg.Callback() end
                    -- flash effect
                    tween(btn, { BackgroundColor3 = Theme.AccentHover }, 0.08)
                    task.wait(0.1)
                    tween(btn, { BackgroundColor3 = Theme.SurfaceLight }, 0.15)
                end)
                return btn
            end

            -- ── Toggle ──
            function sec:Toggle(togCfg)
                togCfg = togCfg or {}
                local state = togCfg.Default or false

                local holder = create("Frame", {
                    Name = togCfg.Name or "Toggle",
                    BackgroundColor3 = Theme.SurfaceLight,
                    Size = UDim2.new(1, 0, 0, 34),
                    Parent = sec.frame,
                })
                addCorner(holder, Theme.CornerRadiusSm)
                addStroke(holder, Theme.Border, 1)

                create("TextLabel", {
                    BackgroundTransparency = 1,
                    Position = UDim2.new(0, 10, 0, 0),
                    Size = UDim2.new(1, -60, 1, 0),
                    Font = Theme.FontLight,
                    Text = togCfg.Name or "Toggle",
                    TextColor3 = Theme.Text,
                    TextSize = 13,
                    TextXAlignment = Enum.TextXAlignment.Left,
                    Parent = holder,
                })

                local track = create("Frame", {
                    BackgroundColor3 = Theme.Border,
                    AnchorPoint = Vector2.new(1, 0.5),
                    Position = UDim2.new(1, -10, 0.5, 0),
                    Size = UDim2.new(0, 36, 0, 18),
                    Parent = holder,
                })
                addCorner(track, UDim.new(1, 0))

                local knob = create("Frame", {
                    BackgroundColor3 = Theme.Text,
                    AnchorPoint = Vector2.new(0, 0.5),
                    Position = UDim2.new(0, 3, 0.5, 0),
                    Size = UDim2.new(0, 12, 0, 12),
                    Parent = track,
                })
                addCorner(knob, UDim.new(1, 0))

                local function updateToggle()
                    if state then
                        tween(track, { BackgroundColor3 = Theme.Accent }, 0.2)
                        tween(knob, { Position = UDim2.new(1, -15, 0.5, 0) }, 0.2)
                    else
                        tween(track, { BackgroundColor3 = Theme.Border }, 0.2)
                        tween(knob, { Position = UDim2.new(0, 3, 0.5, 0) }, 0.2)
                    end
                end
                updateToggle()

                local btn = create("TextButton", {
                    BackgroundTransparency = 1,
                    Size = UDim2.new(1, 0, 1, 0),
                    Text = "",
                    Parent = holder,
                })
                btn.MouseButton1Click:Connect(function()
                    state = not state
                    updateToggle()
                    if togCfg.Callback then togCfg.Callback(state) end
                end)

                local api = {}
                function api:Set(val) state = val; updateToggle() end
                function api:Get() return state end
                return api
            end

            -- ── Slider ──
            function sec:Slider(slCfg)
                slCfg = slCfg or {}
                local min = slCfg.Min or 0
                local max = slCfg.Max or 100
                local val = slCfg.Default or min
                local suffix = slCfg.Suffix or ""

                local holder = create("Frame", {
                    Name = slCfg.Name or "Slider",
                    BackgroundColor3 = Theme.SurfaceLight,
                    Size = UDim2.new(1, 0, 0, 48),
                    Parent = sec.frame,
                })
                addCorner(holder, Theme.CornerRadiusSm)
                addStroke(holder, Theme.Border, 1)

                local label = create("TextLabel", {
                    BackgroundTransparency = 1,
                    Position = UDim2.new(0, 10, 0, 0),
                    Size = UDim2.new(1, -20, 0, 24),
                    Font = Theme.FontLight,
                    Text = (slCfg.Name or "Slider") .. ": " .. tostring(val) .. suffix,
                    TextColor3 = Theme.Text,
                    TextSize = 13,
                    TextXAlignment = Enum.TextXAlignment.Left,
                    Parent = holder,
                })

                local trackBg = create("Frame", {
                    BackgroundColor3 = Theme.Border,
                    Position = UDim2.new(0, 10, 0, 30),
                    Size = UDim2.new(1, -20, 0, 6),
                    Parent = holder,
                })
                addCorner(trackBg, UDim.new(1, 0))

                local fill = create("Frame", {
                    BackgroundColor3 = Theme.Accent,
                    Size = UDim2.new((val - min) / (max - min), 0, 1, 0),
                    Parent = trackBg,
                })
                addCorner(fill, UDim.new(1, 0))

                local sliderBtn = create("TextButton", {
                    BackgroundTransparency = 1,
                    Size = UDim2.new(1, 0, 1, 0),
                    Text = "",
                    Parent = holder,
                })

                local sliding = false
                sliderBtn.InputBegan:Connect(function(input)
                    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                        sliding = true
                    end
                end)
                sliderBtn.InputEnded:Connect(function(input)
                    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                        sliding = false
                    end
                end)
                UserInputService.InputChanged:Connect(function(input)
                    if sliding and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
                        local rel = math.clamp((input.Position.X - trackBg.AbsolutePosition.X) / trackBg.AbsoluteSize.X, 0, 1)
                        val = math.floor(min + (max - min) * rel)
                        fill.Size = UDim2.new(rel, 0, 1, 0)
                        label.Text = (slCfg.Name or "Slider") .. ": " .. tostring(val) .. suffix
                        if slCfg.Callback then slCfg.Callback(val) end
                    end
                end)

                local api = {}
                function api:Set(v) val = math.clamp(v, min, max); local r = (val-min)/(max-min); fill.Size = UDim2.new(r,0,1,0); label.Text = (slCfg.Name or "Slider")..": "..tostring(val)..suffix end
                function api:Get() return val end
                return api
            end

            -- ── Dropdown ──
            function sec:Dropdown(ddCfg)
                ddCfg = ddCfg or {}
                local options = ddCfg.Options or {}
                local selected = ddCfg.Default or (options[1] or "")
                local opened = false

                local holder = create("Frame", {
                    Name = ddCfg.Name or "Dropdown",
                    BackgroundColor3 = Theme.SurfaceLight,
                    Size = UDim2.new(1, 0, 0, 34),
                    ClipsDescendants = true,
                    Parent = sec.frame,
                })
                addCorner(holder, Theme.CornerRadiusSm)
                addStroke(holder, Theme.Border, 1)

                local header = create("TextButton", {
                    BackgroundTransparency = 1,
                    Size = UDim2.new(1, 0, 0, 34),
                    Font = Theme.FontLight,
                    Text = "  " .. (ddCfg.Name or "Dropdown") .. ": " .. tostring(selected),
                    TextColor3 = Theme.Text,
                    TextSize = 13,
                    TextXAlignment = Enum.TextXAlignment.Left,
                    Parent = holder,
                })

                local arrow = create("TextLabel", {
                    BackgroundTransparency = 1,
                    AnchorPoint = Vector2.new(1, 0),
                    Position = UDim2.new(1, -10, 0, 0),
                    Size = UDim2.new(0, 20, 0, 34),
                    Font = Theme.Font,
                    Text = "▸",
                    TextColor3 = Theme.TextDim,
                    TextSize = 14,
                    Parent = holder,
                })

                local optHolder = create("Frame", {
                    BackgroundTransparency = 1,
                    Position = UDim2.new(0, 0, 0, 34),
                    Size = UDim2.new(1, 0, 0, 0),
                    AutomaticSize = Enum.AutomaticSize.Y,
                    Parent = holder,
                })
                create("UIListLayout", { SortOrder = Enum.SortOrder.LayoutOrder, Padding = UDim.new(0,2), Parent = optHolder })
                addPadding(optHolder, UDim.new(0,4), UDim.new(0,4), UDim.new(0,4), UDim.new(0,4))

                local function buildOptions()
                    for _, c in ipairs(optHolder:GetChildren()) do
                        if c:IsA("TextButton") then c:Destroy() end
                    end
                    for _, opt in ipairs(options) do
                        local ob = create("TextButton", {
                            BackgroundColor3 = Theme.Surface,
                            BackgroundTransparency = 0.5,
                            Size = UDim2.new(1, 0, 0, 28),
                            Font = Theme.FontLight,
                            Text = tostring(opt),
                            TextColor3 = (opt == selected) and Theme.Accent or Theme.TextDim,
                            TextSize = 13,
                            Parent = optHolder,
                        })
                        addCorner(ob, Theme.CornerRadiusSm)
                        ob.MouseEnter:Connect(function() tween(ob, { BackgroundTransparency = 0, TextColor3 = Theme.Text }, 0.1) end)
                        ob.MouseLeave:Connect(function() tween(ob, { BackgroundTransparency = 0.5, TextColor3 = (opt == selected) and Theme.Accent or Theme.TextDim }, 0.1) end)
                        ob.MouseButton1Click:Connect(function()
                            selected = opt
                            header.Text = "  " .. (ddCfg.Name or "Dropdown") .. ": " .. tostring(selected)
                            if ddCfg.Callback then ddCfg.Callback(selected) end
                            -- close
                            opened = false
                            tween(holder, { Size = UDim2.new(1, 0, 0, 34) }, 0.2)
                            tween(arrow, { Rotation = 0 }, 0.2)
                            buildOptions()
                        end)
                    end
                end
                buildOptions()

                header.MouseButton1Click:Connect(function()
                    opened = not opened
                    if opened then
                        local h = 34 + 8 + #options * 30
                        tween(holder, { Size = UDim2.new(1, 0, 0, h) }, 0.25)
                        tween(arrow, { Rotation = 90 }, 0.2)
                    else
                        tween(holder, { Size = UDim2.new(1, 0, 0, 34) }, 0.2)
                        tween(arrow, { Rotation = 0 }, 0.2)
                    end
                end)

                local api = {}
                function api:Set(v) selected = v; header.Text = "  "..(ddCfg.Name or "Dropdown")..": "..tostring(v); buildOptions() end
                function api:Get() return selected end
                function api:Refresh(newOpts) options = newOpts; buildOptions() end
                return api
            end

            -- ── TextInput ──
            function sec:TextInput(tiCfg)
                tiCfg = tiCfg or {}

                local holder = create("Frame", {
                    Name = tiCfg.Name or "TextInput",
                    BackgroundColor3 = Theme.SurfaceLight,
                    Size = UDim2.new(1, 0, 0, 34),
                    Parent = sec.frame,
                })
                addCorner(holder, Theme.CornerRadiusSm)
                addStroke(holder, Theme.Border, 1)

                create("TextLabel", {
                    BackgroundTransparency = 1,
                    Position = UDim2.new(0, 10, 0, 0),
                    Size = UDim2.new(0.45, 0, 1, 0),
                    Font = Theme.FontLight,
                    Text = tiCfg.Name or "Input",
                    TextColor3 = Theme.Text,
                    TextSize = 13,
                    TextXAlignment = Enum.TextXAlignment.Left,
                    Parent = holder,
                })

                local box = create("TextBox", {
                    BackgroundColor3 = Theme.Background,
                    AnchorPoint = Vector2.new(1, 0.5),
                    Position = UDim2.new(1, -6, 0.5, 0),
                    Size = UDim2.new(0.5, -10, 0, 24),
                    Font = Theme.FontLight,
                    Text = tiCfg.Default or "",
                    PlaceholderText = tiCfg.Placeholder or "...",
                    PlaceholderColor3 = Theme.TextDim,
                    TextColor3 = Theme.Text,
                    TextSize = 13,
                    ClearTextOnFocus = false,
                    Parent = holder,
                })
                addCorner(box, Theme.CornerRadiusSm)

                box.FocusLost:Connect(function()
                    if tiCfg.Callback then tiCfg.Callback(box.Text) end
                end)

                local api = {}
                function api:Set(v) box.Text = v end
                function api:Get() return box.Text end
                return api
            end

            -- ── Label ──
            function sec:Label(text)
                local lbl = create("TextLabel", {
                    Name = "Label",
                    BackgroundTransparency = 1,
                    Size = UDim2.new(1, 0, 0, 20),
                    Font = Theme.FontLight,
                    Text = text or "",
                    TextColor3 = Theme.TextDim,
                    TextSize = 13,
                    TextXAlignment = Enum.TextXAlignment.Left,
                    TextWrapped = true,
                    AutomaticSize = Enum.AutomaticSize.Y,
                    Parent = sec.frame,
                })
                local api = {}
                function api:Set(t) lbl.Text = t end
                return api
            end

            -- ── Keybind ──
            function sec:Keybind(kbCfg)
                kbCfg = kbCfg or {}
                local key = kbCfg.Default or Enum.KeyCode.Unknown
                local listening = false

                local holder = create("Frame", {
                    Name = kbCfg.Name or "Keybind",
                    BackgroundColor3 = Theme.SurfaceLight,
                    Size = UDim2.new(1, 0, 0, 34),
                    Parent = sec.frame,
                })
                addCorner(holder, Theme.CornerRadiusSm)
                addStroke(holder, Theme.Border, 1)

                create("TextLabel", {
                    BackgroundTransparency = 1,
                    Position = UDim2.new(0, 10, 0, 0),
                    Size = UDim2.new(1, -80, 1, 0),
                    Font = Theme.FontLight,
                    Text = kbCfg.Name or "Keybind",
                    TextColor3 = Theme.Text,
                    TextSize = 13,
                    TextXAlignment = Enum.TextXAlignment.Left,
                    Parent = holder,
                })

                local keyBtn = create("TextButton", {
                    BackgroundColor3 = Theme.Background,
                    AnchorPoint = Vector2.new(1, 0.5),
                    Position = UDim2.new(1, -8, 0.5, 0),
                    Size = UDim2.new(0, 60, 0, 24),
                    Font = Theme.FontLight,
                    Text = key.Name or "...",
                    TextColor3 = Theme.Accent,
                    TextSize = 12,
                    Parent = holder,
                })
                addCorner(keyBtn, Theme.CornerRadiusSm)

                keyBtn.MouseButton1Click:Connect(function()
                    listening = true
                    keyBtn.Text = "..."
                    tween(keyBtn, { TextColor3 = Theme.Warning }, 0.15)
                end)

                UserInputService.InputBegan:Connect(function(input, gpe)
                    if listening and input.UserInputType == Enum.UserInputType.Keyboard then
                        key = input.KeyCode
                        keyBtn.Text = key.Name
                        tween(keyBtn, { TextColor3 = Theme.Accent }, 0.15)
                        listening = false
                        if kbCfg.Callback then kbCfg.Callback(key) end
                    elseif not gpe and input.KeyCode == key and not listening then
                        if kbCfg.OnPress then kbCfg.OnPress() end
                    end
                end)

                local api = {}
                function api:Set(k) key = k; keyBtn.Text = k.Name end
                function api:Get() return key end
                return api
            end

            return sec
        end

        return tab
    end

    table.insert(self.windows, win)
    return win
end

-- ── Destroy ────────────────────────────────────────────
function Library:Destroy()
    if self._toggleConn then self._toggleConn:Disconnect() end
    if self.gui then self.gui:Destroy() end
end

return Library
